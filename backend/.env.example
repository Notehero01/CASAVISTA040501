# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Admin Credentials
ADMIN_EMAIL=info@casavista.it
ADMIN_PASSWORD=ChangeThisStrongPassword123!

# Upload Configuration
DATA_DIR=./data
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880
CLIENT_ORIGIN=http://localhost:3000

# Email SMTP, esempio Aruba
SMTP_HOST=smtps.aruba.it
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@casavista.it
SMTP_PASS=password-casella-email
EMAIL_FROM=CasaVista <noreply@casavista.it>

# Email via Brevo API, consigliato se lo SMTP non e raggiungibile dal server
# BREVO_API_KEY=xkeysib-la-tua-api-key
# EMAIL_FROM=CasaVista <noreply@casavista.it>
